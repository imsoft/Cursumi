// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  complete
  current
  upcoming
}

enum Gender {
  man
  woman
  other
}

model User {
  id       String @id @default(uuid())
  name     String
  surname  String
  email    String @unique
  password String
  role     String
  // Course   Course[]
}

model Course {
  id          String @id @default(uuid())
  title       String
  description String
  price       Float

  // user   User   @relation(fields: [userId], references: [id])
  // userId String

  // CourseChapter CourseChapter[]
}

model CourseChapter {
  id       String @id @default(uuid())
  title    String
  videoUrl String
  status   Status

  // course   Course @relation(fields: [courseId], references: [id])
  // courseId String
}
