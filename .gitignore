# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencias
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Pruebas y cobertura
/coverage
/test-results/
/playwright-report/
/blob-report/

# Next.js
/.next/
/out/

# Producción
/build

# Varios
.DS_Store
Thumbs.db
*.pem

# Depuración
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# Variables de entorno (secretos locales; la plantilla .env.example sí se versiona)
.env
.env.*
!.env.example

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Herramientas
.eslintcache

# Claude Code / agentes de IA en el repo
# — .agents/skills: skills compartidas (Markdown, scripts); conviene versionarlas.
# — .claude/skills: suelen ser symlinks → .agents/skills para que Claude Code las detecte.
# — Ajustes de Claude en tu máquina (permisos, rutas absolutas; no subir):
.claude/settings.json
.claude/settings.local.json
