// Prisma Schema para Better Auth con Neon PostgreSQL

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// AUTH (Better Auth)
// ─────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  phone         String?
  city          String?
  /// Entidad federativa (México), va con `city` (municipio)
  state         String?
  bio           String?
  website       String?
  linkedinUrl   String?
  instagramUrl  String?
  signatureUrl  String?
  role          Role     @default(student)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts                  Account[]
  sessions                  Session[]
  instructorProfile         InstructorProfile?
  instructorApplication     InstructorApplication?
  instructorCourses         Course[]                   @relation("InstructorCourses")
  enrollments               Enrollment[]               @relation("StudentEnrollments")
  certificates              Certificate[]
  transactions              Transaction[]
  reviews                   Review[]
  notifications             Notification[]
  studentConversations      Conversation[]             @relation("StudentConversations")
  instructorConversations   Conversation[]             @relation("InstructorConversations")
  sentMessages              Message[]
  hostedGames               QuizGame[]
  gameParticipations        QuizGameParticipant[]
  orgMemberships            OrgMember[]
  courseNotes               CourseNote[]
  sessionAnonymousQuestions SessionAnonymousQuestion[]
  learningReflections       LearningReflection[]
  wishlistItems             WishlistItem[]
  pushSubscriptions         PushSubscription[]

  /// Código único para compartir — generado al crear la cuenta
  referralCode        String?    @unique
  /// Usuario que refirió a este usuario (null si llegó sin referido)
  referredById        String?
  referredBy          User?      @relation("UserReferrals", fields: [referredById], references: [id])
  referrals           User[]     @relation("UserReferrals")
  /// Comisiones que este usuario ha generado como referidor
  referralCommissions Referral[]
  /// Entrada de referido de este usuario (solo existe si fue referido por alguien)
  referralEntry       Referral?  @relation("ReferredUser")
  blogPosts           BlogPost[] @relation("BlogAuthor")
}

model Account {
  id                   String    @id @default(cuid())
  userId               String
  accountId            String
  providerId           String
  accessToken          String?   @db.Text
  refreshToken         String?   @db.Text
  idToken              String?   @db.Text
  expiresAt            DateTime?
  accessTokenExpiresAt DateTime?
  scope                String?
  password             String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier, value])
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  student
  instructor
  admin
}

enum Modality {
  virtual
  presencial
  live
}

enum CourseType {
  fechado
  ondemand
}

enum CourseStatus {
  draft
  published
  archived
}

enum LessonType {
  video
  text
  quiz
  assignment
  /// Test (misma estructura que el antiguo test al final de sección); contenido JSON = SectionQuiz
  section_quiz
  /// Minijuego; contenido JSON = SectionMinigame
  section_minigame
}

enum EnrollmentStatus {
  active
  completed
  cancelled
}

enum ApplicationStatus {
  pending
  approved
  rejected
}

enum TransactionStatus {
  pending
  completed
  failed
  refunded
}

enum ReferralStatus {
  pending // registrado pero sin compra aún
  earned // primera compra completada — comisión acumulada
  paid // comisión pagada al referidor
}

// ── CURSUMI BUSINESS ──

enum OrgRole {
  owner
  admin
  member
}

enum OrgInviteStatus {
  pending
  accepted
  expired
}

enum OrgSubscriptionStatus {
  active
  past_due
  canceled
  trialing
}

enum CourseVisibility {
  public
  business_only
  both
}

// ─────────────────────────────────────────
// INSTRUCTORES
// ─────────────────────────────────────────

model InstructorApplication {
  id              String            @id @default(cuid())
  userId          String            @unique
  status          ApplicationStatus @default(pending)
  headline        String?
  bio             String?           @db.Text
  reason          String            @db.Text
  rejectionReason String?           @db.Text
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model InstructorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  headline        String?
  bio             String?
  city            String?
  state           String?
  specialties     String? // CSV de categorías/habilidades
  teachingYears   Int?
  website         String?
  linkedinUrl     String?
  instagramUrl    String?
  stripeAccountId String?  @unique // Stripe Connect account ID — un ID por instructor
  stripeOnboarded Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// CATEGORÍAS
// ─────────────────────────────────────────

model Category {
  id      String   @id @default(cuid())
  name    String   @unique
  slug    String   @unique
  order   Int      @default(0)
  courses Course[]
}

// ─────────────────────────────────────────
// CURSOS
// ─────────────────────────────────────────

model Course {
  id           String           @id @default(cuid())
  slug         String?          @unique // {título-slugificado}-por-{instructor-slug}
  instructorId String
  title        String
  description  String
  category     String // string libre (legacy + compatibilidad)
  categoryId   String? // FK opcional a Category
  level        String?
  modality     Modality
  city         String?
  state        String?
  location     String?
  mapsUrl      String?
  courseType   CourseType
  startDate    DateTime?
  duration     String?
  price        Int
  maxStudents  Int?
  imageUrl     String?
  status       CourseStatus     @default(draft)
  visibility   CourseVisibility @default(public)
  nextSession  DateTime?
  finalExam    Json? // CourseFinalExam serializado
  /// Hash (scrypt) del código de inscripción para cursos presenciales gratuitos; null = abierto
  joinCodeHash String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  instructor                User                       @relation("InstructorCourses", fields: [instructorId], references: [id], onDelete: Cascade)
  categoryRef               Category?                  @relation(fields: [categoryId], references: [id])
  sections                  CourseSection[]
  courseSessions            CourseSession[]
  enrollments               Enrollment[]
  certificates              Certificate[]
  transactions              Transaction[]
  reviews                   Review[]
  conversations             Conversation[]
  orgCourseAccess           OrgCourseAccess[]
  teamCourseAccess          TeamCourseAccess[]
  notes                     CourseNote[]
  sessionAnonymousQuestions SessionAnonymousQuestion[]
  learningReflections       LearningReflection[]
  wishlistItems             WishlistItem[]
  coupons                   Coupon[]

  @@index([instructorId])
  @@index([status])
  @@index([category])
  @@index([categoryId])
}

model CourseSection {
  id          String  @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int
  quiz        Json? // legacy: un solo test (se migra a activities al guardar desde el editor)
  minigame    Json? // legacy: un solo minijuego
  activities  Json? // SectionActivity[]: varios tests y minijuegos con id estable por actividad

  course                 Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons                Lesson[]
  sectionQuizSubmissions SectionQuizSubmission[]

  @@index([courseId, order])
}

model Lesson {
  id          String     @id @default(cuid())
  sectionId   String
  title       String
  description String?
  type        LessonType
  duration    String?
  order       Int
  videoUrl    String?
  content     String?    @db.Text
  attachments Json? // CourseFile[] — PDFs y archivos descargables
  resources   Json? // CourseResource[] — enlaces externos
  isFree      Boolean    @default(false) // Preview gratuita — visible sin enrolamiento
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  section               CourseSection          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress              LessonProgress[]
  notes                 CourseNote[]
  assignmentSubmissions AssignmentSubmission[]

  @@index([sectionId, order])
}

model LessonProgress {
  id           String   @id @default(cuid())
  enrollmentId String
  lessonId     String
  completedAt  DateTime @default(now())
  score        Int? // 0-100, para lecciones tipo quiz
  answers      Json? // Respuestas del quiz guardadas

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([lessonId])
  @@index([enrollmentId])
}

// ─────────────────────────────────────────
// SESIONES PRESENCIALES
// ─────────────────────────────────────────

model CourseSession {
  id           String   @id @default(cuid())
  courseId     String
  city         String
  state        String?
  location     String // dirección/sede (presencial) o texto corto (en vivo)
  /// Meet, Zoom, Teams, etc. — principalmente para modalidad live
  meetingUrl   String?
  date         DateTime
  startTime    String // "09:00"
  endTime      String // "13:00"
  maxStudents  Int
  /// Hash del código de acceso específico de esta sesión (bcrypt/scrypt)
  joinCodeHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course             Course                     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollments        Enrollment[]
  anonymousQuestions SessionAnonymousQuestion[]

  @@index([courseId])
  @@index([courseId, date])
}

enum SessionAnonymousQuestionStatus {
  open
  answered
  dismissed
}

// Preguntas en vivo durante clase presencial (autor oculto para el instructor en la UI)
model SessionAnonymousQuestion {
  id              String                         @id @default(cuid())
  courseSessionId String
  courseId        String
  authorId        String
  content         String                         @db.Text
  status          SessionAnonymousQuestionStatus @default(open)
  answer          String?                        @db.Text
  answeredAt      DateTime?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  session CourseSession @relation(fields: [courseSessionId], references: [id], onDelete: Cascade)
  course  Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  author  User          @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([courseSessionId, createdAt])
  @@index([courseId])
  @@index([authorId])
}

// ─────────────────────────────────────────
// INSCRIPCIONES
// ─────────────────────────────────────────

model Enrollment {
  id             String           @id @default(cuid())
  courseId       String
  studentId      String
  sessionId      String? // null para cursos virtuales; requerido para presenciales
  organizationId String? // null para compras individuales; set para inscripciones org
  status         EnrollmentStatus @default(active)
  progress       Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  course                        Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student                       User                    @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)
  session                       CourseSession?          @relation(fields: [sessionId], references: [id])
  organization                  Organization?           @relation(fields: [organizationId], references: [id])
  lessonProgress                LessonProgress[]
  certificate                   Certificate?
  examSubmission                ExamSubmission?
  transaction                   Transaction?
  sectionQuizSubmissions        SectionQuizSubmission[]
  assignmentSubmissions         AssignmentSubmission[]
  learningReflectionEmailSentAt DateTime?
  learningReflection            LearningReflection?

  @@unique([courseId, studentId])
  @@index([studentId])
  @@index([sessionId])
  @@index([organizationId])
}

// Respuesta a "¿Qué aprendiste?" — visible en la ficha pública del curso
model LearningReflection {
  id           String   @id @default(cuid())
  enrollmentId String   @unique
  courseId     String
  userId       String
  content      String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([userId])
}

// ─────────────────────────────────────────
// TEST DE SECCIÓN
// ─────────────────────────────────────────

model SectionQuizSubmission {
  id           String   @id @default(cuid())
  enrollmentId String
  sectionId    String
  activityId   String   @default("default") // id de la actividad en CourseSection.activities (o "default" legacy)
  score        Int // 0-100
  passed       Boolean
  submittedAt  DateTime @default(now())

  enrollment Enrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  section    CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, sectionId, activityId])
  @@index([sectionId])
}

// ─────────────────────────────────────────
// TAREAS (ASSIGNMENT SUBMISSIONS)
// ─────────────────────────────────────────

model AssignmentSubmission {
  id           String   @id @default(cuid())
  enrollmentId String
  lessonId     String
  content      String   @db.Text
  submittedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([lessonId])
  @@index([enrollmentId])
}

// ─────────────────────────────────────────
// EXAMEN FINAL
// ─────────────────────────────────────────

model ExamSubmission {
  id           String   @id @default(cuid())
  enrollmentId String   @unique
  answers      Json // { [questionId]: answeredOption }
  score        Int // 0-100
  passed       Boolean
  submittedAt  DateTime @default(now())

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// CERTIFICADOS
// ─────────────────────────────────────────

enum CertificateType {
  accreditation // Aprobó el examen
  participation // Completó el curso pero no aprobó el examen
}

model Certificate {
  id           String          @id @default(cuid())
  enrollmentId String          @unique
  userId       String
  courseId     String
  number       String          @unique // CUR-XXXXXXXXXX
  type         CertificateType @default(accreditation)
  issuedAt     DateTime        @default(now())

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
}

// ─────────────────────────────────────────
// TRANSACCIONES / PAGOS
// ─────────────────────────────────────────

model Transaction {
  id               String            @id @default(cuid())
  enrollmentId     String?           @unique
  userId           String
  courseId         String
  amount           Int // centavos MXN
  currency         String            @default("MXN")
  status           TransactionStatus @default(pending)
  stripePaymentId  String?
  stripeSessionId  String?           @unique
  platformFee      Int?
  instructorAmount Int?
  couponCode       String? // cupón aplicado al momento del pago
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  enrollment Enrollment? @relation(fields: [enrollmentId], references: [id])
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  referral   Referral?

  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@index([userId, courseId, status]) // acelera findFirst en checkout (pending transactions)
}

// ─────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  rating    Int // 1-5
  comment   String?
  approved  Boolean  @default(false) // requiere aprobación del admin antes de publicarse
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([approved])
}

// ─────────────────────────────────────────
// NOTIFICACIONES
// ─────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // enrollment | lesson_complete | certificate | message | review
  title     String
  body      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ─────────────────────────────────────────
// MENSAJERÍA
// ─────────────────────────────────────────

model Conversation {
  id           String   @id @default(cuid())
  courseId     String
  studentId    String
  instructorId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course     Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student    User      @relation("StudentConversations", fields: [studentId], references: [id], onDelete: Cascade)
  instructor User      @relation("InstructorConversations", fields: [instructorId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@unique([courseId, studentId, instructorId])
  @@index([studentId])
  @@index([instructorId])
  @@index([courseId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String   @db.Text
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

enum GameStatus {
  waiting
  active
  finished
}

model QuizGame {
  id                String     @id @default(cuid())
  code              String     @unique
  title             String
  hostId            String
  status            GameStatus @default(waiting)
  currentQuestion   Int        @default(0)
  questionStartedAt DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  host         User                  @relation(fields: [hostId], references: [id])
  questions    QuizGameQuestion[]
  participants QuizGameParticipant[]
  answers      QuizGameAnswer[]

  @@index([code])
  @@index([hostId])
  @@index([status])
}

model QuizGameQuestion {
  id           String @id @default(cuid())
  gameId       String
  order        Int
  question     String @db.Text
  options      Json
  correct      Int
  timeLimitSec Int    @default(20)
  points       Int    @default(1000)

  game    QuizGame         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  answers QuizGameAnswer[]

  @@index([gameId])
}

model QuizGameParticipant {
  id       String   @id @default(cuid())
  gameId   String
  userId   String
  nickname String
  score    Int      @default(0)
  joinedAt DateTime @default(now())

  game    QuizGame         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id])
  answers QuizGameAnswer[]

  @@unique([gameId, userId])
  @@index([gameId])
}

model QuizGameAnswer {
  id             String   @id @default(cuid())
  gameId         String
  questionId     String
  participantId  String
  selectedOption Int
  isCorrect      Boolean
  pointsEarned   Int      @default(0)
  answeredAt     DateTime @default(now())

  game        QuizGame            @relation(fields: [gameId], references: [id], onDelete: Cascade)
  question    QuizGameQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  participant QuizGameParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([questionId, participantId])
  @@index([gameId])
  @@index([participantId])
}

// ─────────────────────────────────────────
// CURSUMI BUSINESS
// ─────────────────────────────────────────

model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logoUrl      String?
  contactEmail String
  contactPhone String?
  address      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members      OrgMember[]
  invitations  OrgInvite[]
  teams        Team[]
  subscription OrgSubscription?
  courseAccess OrgCourseAccess[]
  materials    OrgMaterial[]
  enrollments  Enrollment[]

  @@index([slug])
}

model OrgMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  orgRole        OrgRole  @default(member)
  joinedAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamMemberships TeamMember[]

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
}

model OrgInvite {
  id             String          @id @default(cuid())
  organizationId String
  email          String
  orgRole        OrgRole         @default(member)
  token          String          @unique @default(cuid())
  status         OrgInviteStatus @default(pending)
  invitedBy      String // userId
  expiresAt      DateTime
  createdAt      DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([token])
}

model Team {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      TeamMember[]
  courseAccess TeamCourseAccess[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model TeamMember {
  id       String @id @default(cuid())
  teamId   String
  memberId String // FK a OrgMember.id

  team   Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  member OrgMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([teamId, memberId])
}

model OrgSubscription {
  id                   String                @id @default(cuid())
  organizationId       String                @unique
  stripeCustomerId     String                @unique
  stripeSubscriptionId String?               @unique
  status               OrgSubscriptionStatus @default(active)
  maxSeats             Int
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model OrgCourseAccess {
  id             String   @id @default(cuid())
  organizationId String
  courseId       String
  grantedAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([organizationId, courseId])
  @@index([organizationId])
  @@index([courseId])
}

model TeamCourseAccess {
  id        String   @id @default(cuid())
  teamId    String
  courseId  String
  grantedAt DateTime @default(now())

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([teamId, courseId])
}

model OrgMaterial {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  fileUrl        String // Cloudinary URL
  fileType       String // "pdf", "docx", etc.
  fileSize       Int? // bytes
  uploadedBy     String // userId
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Kpi {
  id           String        @id @default(cuid())
  name         String
  description  String?       @db.Text
  unit         String        @default("")
  targetValue  Float
  currentValue Float         @default(0)
  period       String        @default("mensual")
  category     String        @default("general")
  deadline     DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  entries      KpiProgress[]

  @@index([category])
}

model KpiProgress {
  id        String   @id @default(cuid())
  kpiId     String
  kpi       Kpi      @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  value     Float // delta incremental de avance
  note      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([kpiId])
}

// ─────────────────────────────────────────
// CONFIGURACIÓN DEL SITIO
// ─────────────────────────────────────────

model SiteSetting {
  key       String   @id // ej: "social_links"
  value     Json // valor serializado
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// CUPONES DE DESCUENTO
// ─────────────────────────────────────────

model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique // código que escribe el usuario, ej. PROMO20
  description String?
  discountPct Int // 1-100 — porcentaje de descuento
  maxUses     Int? // null = ilimitado
  usedCount   Int       @default(0)
  active      Boolean   @default(true)
  expiresAt   DateTime?
  courseId    String? // null = aplica a cualquier curso
  course      Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([code])
  @@index([active])
  @@index([courseId])
}

// ─────────────────────────────────────────
// ANOTACIONES (Course Notes)
// ─────────────────────────────────────────

model CourseNote {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  lessonId  String?
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([courseId])
  @@index([lessonId])
}

// WISHLIST
// ─────────────────────────────────────────

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
}

// ─────────────────────────────────────────
// REFERIDOS
// ─────────────────────────────────────────

model Referral {
  id               String         @id @default(cuid())
  /// El usuario que compartió su link (referidor)
  referrerId       String
  /// El usuario nuevo que se registró con el link
  referredUserId   String         @unique
  /// Transacción que activó la comisión (primera compra del referido)
  transactionId    String?        @unique
  /// Comisión en centavos MXN (10 % del monto neto de la transacción)
  commissionAmount Int?
  status           ReferralStatus @default(pending)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  referrer     User         @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser User         @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
  transaction  Transaction? @relation(fields: [transactionId], references: [id])

  @@index([referrerId])
  @@index([status])
}

// ─────────────────────────────────────────
// WEB PUSH
// ─────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  /// { p256dh: string; auth: string }
  keys      Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────
// BLOG
// ─────────────────────────────────────────

model BlogPost {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  excerpt       String?
  content       String    @db.Text
  coverImageUrl String?
  published     Boolean   @default(false)
  publishedAt   DateTime?
  tags          String[]  @default([])
  authorId      String
  author        User      @relation("BlogAuthor", fields: [authorId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([published])
  @@index([slug])
  @@index([authorId])
}
