// Prisma Schema para Better Auth con Neon PostgreSQL

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// AUTH (Better Auth)
// ─────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  role          Role     @default(student)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts                Account[]
  sessions                Session[]
  instructorProfile       InstructorProfile?
  instructorApplication   InstructorApplication?
  instructorCourses       Course[]               @relation("InstructorCourses")
  enrollments             Enrollment[]           @relation("StudentEnrollments")
  certificates            Certificate[]
  transactions            Transaction[]
  reviews                 Review[]
  notifications           Notification[]
  studentConversations    Conversation[]         @relation("StudentConversations")
  instructorConversations Conversation[]         @relation("InstructorConversations")
  sentMessages            Message[]
  hostedGames             QuizGame[]
  gameParticipations      QuizGameParticipant[]
}

model Account {
  id                   String    @id @default(cuid())
  userId               String
  accountId            String
  providerId           String
  accessToken          String?   @db.Text
  refreshToken         String?   @db.Text
  idToken              String?   @db.Text
  expiresAt            DateTime?
  accessTokenExpiresAt DateTime?
  scope                String?
  password             String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier, value])
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  student
  instructor
  admin
}

enum Modality {
  virtual
  presencial
}

enum CourseType {
  fechado
  ondemand
}

enum CourseStatus {
  draft
  published
  archived
}

enum LessonType {
  video
  text
  quiz
  assignment
}

enum EnrollmentStatus {
  active
  completed
  cancelled
}

enum ApplicationStatus {
  pending
  approved
  rejected
}

enum TransactionStatus {
  pending
  completed
  failed
  refunded
}

// ─────────────────────────────────────────
// INSTRUCTORES
// ─────────────────────────────────────────

model InstructorApplication {
  id              String            @id @default(cuid())
  userId          String            @unique
  status          ApplicationStatus @default(pending)
  headline        String?
  bio             String?           @db.Text
  reason          String            @db.Text
  rejectionReason String?           @db.Text
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model InstructorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  headline        String?
  bio             String?
  city            String?
  specialties     String? // CSV de categorías/habilidades
  stripeAccountId String?  @unique // Stripe Connect account ID — un ID por instructor
  stripeOnboarded Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// CATEGORÍAS
// ─────────────────────────────────────────

model Category {
  id      String   @id @default(cuid())
  name    String   @unique
  slug    String   @unique
  order   Int      @default(0)
  courses Course[]
}

// ─────────────────────────────────────────
// CURSOS
// ─────────────────────────────────────────

model Course {
  id           String       @id @default(cuid())
  instructorId String
  title        String
  description  String
  category     String // string libre (legacy + compatibilidad)
  categoryId   String? // FK opcional a Category
  level        String?
  modality     Modality
  city         String?
  location     String?
  courseType   CourseType
  startDate    DateTime?
  duration     String?
  price        Int
  maxStudents  Int?
  imageUrl     String?
  status       CourseStatus @default(draft)
  nextSession  DateTime?
  finalExam    Json? // CourseFinalExam serializado
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  instructor    User            @relation("InstructorCourses", fields: [instructorId], references: [id], onDelete: Cascade)
  categoryRef   Category?       @relation(fields: [categoryId], references: [id])
  sections      CourseSection[]
  enrollments   Enrollment[]
  certificates  Certificate[]
  transactions  Transaction[]
  reviews       Review[]
  conversations Conversation[]

  @@index([instructorId])
  @@index([status])
  @@index([category])
  @@index([categoryId])
}

model CourseSection {
  id          String  @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int
  quiz        Json? // SectionQuiz: { passingScore: number, questions: Array<{ question, options, correct }> }
  minigame    Json? // SectionMinigame: { type: "memory"|"hangman"|"sort", ... }

  course                 Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons                Lesson[]
  sectionQuizSubmissions SectionQuizSubmission[]

  @@index([courseId, order])
}

model Lesson {
  id          String     @id @default(cuid())
  sectionId   String
  title       String
  description String?
  type        LessonType
  duration    String?
  order       Int
  videoUrl    String?
  content     String?    @db.Text
  attachments Json? // CourseFile[] — PDFs y archivos descargables
  resources   Json? // CourseResource[] — enlaces externos
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  section  CourseSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@index([sectionId, order])
}

model LessonProgress {
  id           String   @id @default(cuid())
  enrollmentId String
  lessonId     String
  completedAt  DateTime @default(now())

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([lessonId])
  @@index([enrollmentId])
}

// ─────────────────────────────────────────
// INSCRIPCIONES
// ─────────────────────────────────────────

model Enrollment {
  id        String           @id @default(cuid())
  courseId  String
  studentId String
  status    EnrollmentStatus @default(active)
  progress  Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  course                 Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student                User                    @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)
  lessonProgress         LessonProgress[]
  certificate            Certificate?
  examSubmission         ExamSubmission?
  transaction            Transaction?
  sectionQuizSubmissions SectionQuizSubmission[]

  @@unique([courseId, studentId])
  @@index([studentId])
}

// ─────────────────────────────────────────
// TEST DE SECCIÓN
// ─────────────────────────────────────────

model SectionQuizSubmission {
  id           String   @id @default(cuid())
  enrollmentId String
  sectionId    String
  score        Int // 0-100
  passed       Boolean
  submittedAt  DateTime @default(now())

  enrollment Enrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  section    CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, sectionId])
  @@index([sectionId])
}

// ─────────────────────────────────────────
// EXAMEN FINAL
// ─────────────────────────────────────────

model ExamSubmission {
  id           String   @id @default(cuid())
  enrollmentId String   @unique
  answers      Json // { [questionId]: answeredOption }
  score        Int // 0-100
  passed       Boolean
  submittedAt  DateTime @default(now())

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// CERTIFICADOS
// ─────────────────────────────────────────

model Certificate {
  id           String   @id @default(cuid())
  enrollmentId String   @unique
  userId       String
  courseId     String
  number       String   @unique // CUR-XXXXXXXXXX
  issuedAt     DateTime @default(now())

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
}

// ─────────────────────────────────────────
// TRANSACCIONES / PAGOS
// ─────────────────────────────────────────

model Transaction {
  id               String            @id @default(cuid())
  enrollmentId     String?           @unique
  userId           String
  courseId         String
  amount           Int // centavos MXN
  currency         String            @default("MXN")
  status           TransactionStatus @default(pending)
  stripePaymentId  String?
  stripeSessionId  String?           @unique
  platformFee      Int?
  instructorAmount Int?
  couponCode       String? // cupón aplicado al momento del pago
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  enrollment Enrollment? @relation(fields: [enrollmentId], references: [id])
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
  @@index([status])
}

// ─────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  rating    Int // 1-5
  comment   String?
  approved  Boolean  @default(false) // requiere aprobación del admin antes de publicarse
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([approved])
}

// ─────────────────────────────────────────
// NOTIFICACIONES
// ─────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // enrollment | lesson_complete | certificate | message | review
  title     String
  body      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ─────────────────────────────────────────
// MENSAJERÍA
// ─────────────────────────────────────────

model Conversation {
  id           String   @id @default(cuid())
  courseId     String
  studentId    String
  instructorId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course     Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student    User      @relation("StudentConversations", fields: [studentId], references: [id], onDelete: Cascade)
  instructor User      @relation("InstructorConversations", fields: [instructorId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@unique([courseId, studentId, instructorId])
  @@index([studentId])
  @@index([instructorId])
  @@index([courseId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String   @db.Text
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

enum GameStatus {
  waiting
  active
  finished
}

model QuizGame {
  id                String     @id @default(cuid())
  code              String     @unique
  title             String
  hostId            String
  status            GameStatus @default(waiting)
  currentQuestion   Int        @default(0)
  questionStartedAt DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  host         User                  @relation(fields: [hostId], references: [id])
  questions    QuizGameQuestion[]
  participants QuizGameParticipant[]
  answers      QuizGameAnswer[]

  @@index([code])
  @@index([hostId])
  @@index([status])
}

model QuizGameQuestion {
  id           String @id @default(cuid())
  gameId       String
  order        Int
  question     String @db.Text
  options      Json
  correct      Int
  timeLimitSec Int    @default(20)
  points       Int    @default(1000)

  game    QuizGame         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  answers QuizGameAnswer[]

  @@index([gameId])
}

model QuizGameParticipant {
  id       String   @id @default(cuid())
  gameId   String
  userId   String
  nickname String
  score    Int      @default(0)
  joinedAt DateTime @default(now())

  game    QuizGame         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id])
  answers QuizGameAnswer[]

  @@unique([gameId, userId])
  @@index([gameId])
}

model QuizGameAnswer {
  id             String   @id @default(cuid())
  gameId         String
  questionId     String
  participantId  String
  selectedOption Int
  isCorrect      Boolean
  pointsEarned   Int      @default(0)
  answeredAt     DateTime @default(now())

  game        QuizGame            @relation(fields: [gameId], references: [id], onDelete: Cascade)
  question    QuizGameQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  participant QuizGameParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([questionId, participantId])
  @@index([gameId])
  @@index([participantId])
}

model Kpi {
  id           String   @id @default(cuid())
  name         String
  description  String?  @db.Text
  unit         String   @default("")
  targetValue  Float
  currentValue Float    @default(0)
  period       String   @default("mensual")
  category     String   @default("general")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
}

// ─────────────────────────────────────────
// CUPONES DE DESCUENTO
// ─────────────────────────────────────────

model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique // código que escribe el usuario, ej. PROMO20
  description String?
  discountPct Int // 1-100 — porcentaje de descuento
  maxUses     Int? // null = ilimitado
  usedCount   Int       @default(0)
  active      Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([code])
  @@index([active])
}
