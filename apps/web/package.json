{
  "name": "@cursumi/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "pnpm db:migrate:deploy && NEXT_USE_TURBOPACK=0 next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:deploy": "if [ \"$VERCEL_ENV\" = \"production\" ]; then PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=true prisma migrate deploy; else echo \"⏭  Skipping prisma migrate deploy (VERCEL_ENV=${VERCEL_ENV:-local}; solo se aplica en producción)\"; fi",
    "db:migrate:diff": "prisma migrate diff --from-config-datasource --to-schema prisma/schema.prisma --script",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@better-auth/expo": "^1.6.11",
    "@cursumi/shared": "workspace:*",
    "@google/genai": "^2.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@lexical/html": "^0.44.0",
    "@lexical/list": "^0.44.0",
    "@lexical/react": "^0.44.0",
    "@lexical/rich-text": "^0.44.0",
    "@lexical/selection": "^0.44.0",
    "@mux/mux-player-react": "^3.13.0",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.53.1",
    "@stripe/stripe-js": "^9.5.0",
    "@upstash/redis": "^1.38.0",
