{
  "name": "@cursumi/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "pnpm db:migrate:deploy && NEXT_USE_TURBOPACK=0 next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:deploy": "if [ \"$VERCEL_ENV\" = \"production\" ]; then PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=true prisma migrate deploy; else echo \"⏭  Skipping prisma migrate deploy (VERCEL_ENV=${VERCEL_ENV:-local}; solo se aplica en producción)\"; fi",
    "db:migrate:diff": "prisma migrate diff --from-config-datasource --to-schema prisma/schema.prisma --script",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@better-auth/expo": "^1.6.23",
    "@cursumi/shared": "workspace:*",
