    "framer-motion": "^12.42.2",
    "html2canvas": "^1.4.1",
    "html2canvas-pro": "^2.2.4",
    "jspdf": "^4.2.1",
    "lexical": "^0.47.0",
    "lucide-react": "^1.24.0",
