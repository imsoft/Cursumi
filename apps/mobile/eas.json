{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal",
        "serviceAccountKeyPath": "./credentials/google-play-service-account.json",
        "releaseStatus": "draft"
      },
      "ios": {
        "ascAppId": "REEMPLAZAR_ASC_APP_ID",
        "appleTeamId": "REEMPLAZAR_APPLE_TEAM_ID"
      }
    }
  }
}
