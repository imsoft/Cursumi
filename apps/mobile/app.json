{
  "expo": {
    "name": "Cursumi",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.cursumi.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.cursumi.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#4f00f6",
          "image": "./assets/images/cursumi-logo.png",
          "imageWidth": 120,
          "android": {
            "image": "./assets/images/cursumi-logo.png",
            "imageWidth": 120
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Cursumi necesita acceso a tus fotos para actualizar tu foto de perfil."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#4f00f6"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
