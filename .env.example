# Base de datos Neon
DATABASE_URL="postgresql://user:password@endpoint.neon.tech:5432/dbname?sslmode=require&channel_binding=require"

# Better Auth
BETTER_AUTH_SECRET="set-a-strong-secret"

# URLs de la app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend (emails de verificación y reset)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Cursumi <onboarding@resend.dev>"

# Bandeja donde llegan los mensajes del formulario /contact (opcional; por defecto contacto@cursumi.com)
# Debe ser un correo que Resend pueda usar como destino (dominio verificado o inbox permitido).
# CONTACT_INBOX_EMAIL="contacto@cursumi.com"

# Cloudinary (imágenes)
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
CLOUDINARY_UPLOAD_PRESET="unsigned"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Mux (video)
MUX_TOKEN_ID="your-mux-token-id"
MUX_TOKEN_SECRET="your-mux-token-secret"

# Stripe (pagos)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Upstash Redis (rate limiting en producción)
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Cloudflare Turnstile (CAPTCHA anti-spam en registro)
# Obtén las claves en: https://dash.cloudflare.com/ → Turnstile → Add site
# TURNSTILE_SECRET_KEY es server-side (nunca exponerla al cliente)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY es client-side (visible en el navegador, es normal)
TURNSTILE_SECRET_KEY="your-turnstile-secret-key"
NEXT_PUBLIC_TURNSTILE_SITE_KEY="your-turnstile-site-key"

# Sentry (monitoreo de errores)
NEXT_PUBLIC_SENTRY_DSN="https://xxx@o0.ingest.sentry.io/0"
SENTRY_DSN="https://xxx@o0.ingest.sentry.io/0"
SENTRY_AUTH_TOKEN="sntrys_xxx"  # para subir source maps en CI

# Web Push / notificaciones en el navegador (opcional)
# Sin estas variables la app funciona; solo no habrá suscripciones push. Ver src/lib/web-push.ts
# NEXT_PUBLIC_VAPID_PUBLIC_KEY es pública (va al cliente); VAPID_PRIVATE_KEY solo en el servidor.
# Generar un par de claves:
#   node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(JSON.stringify(k))"
# NEXT_PUBLIC_VAPID_PUBLIC_KEY="BGx..."
# VAPID_PRIVATE_KEY="..."
# VAPID_CONTACT_EMAIL="contacto@cursumi.com"

# Cron jobs
CRON_SECRET="un-string-aleatorio-seguro"  # protege /api/cron/progress-reminders

# Evitar fallos de descarga de fuentes (entornos sin red)
NEXT_FONT_IGNORE_FAILED_DOWNLOADS=1
# NEXT_USE_TURBOPACK=0  # descomenta si el build falla con Turbopack (no recomendado en producción)

# Contacto
CONTACT_INBOX_EMAIL="cursumi.com@gmail.com"